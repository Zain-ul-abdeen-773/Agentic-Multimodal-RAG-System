# ============================================================
# Environment Variables — Copy to .env and fill in values
# ============================================================

# Groq API (free tier — https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Neo4j Aura Free Tier (https://neo4j.com/cloud/aura-free/)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# HuggingFace (optional, for gated models)
HF_TOKEN=hf_your_token_here

# Ollama (local VLM server)
OLLAMA_BASE_URL=http://localhost:11434

# Device
DEVICE=cuda  # or cpu
